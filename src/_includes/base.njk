<!doctype html>
<html lang="en-US">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}{% if title != "Aspire Fellowship" %} | Aspire Fellowship{% endif %}</title>
  <meta name="description" content="{{ description or 'A selective 12 week program that helps ambitious students create graduate-level research through elite mentorship.' }}">
  <link rel="icon" href="/favicon.png">
  <link rel="apple-touch-icon" href="/favicon.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  {% include "header.njk" %}
  <main id="main">
    {{ content | safe }}
  </main>
  {% include "footer.njk" %}
  <script src="/js/main.js" defer></script>
</body>
</html>
