<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="brand" aria-label="Aspire Research home">
      <img src="/assets/images/logos/aspire-mark.png" alt="" class="brand__mark" width="28" height="28">
    </a>
    <span class="site-header__divider" aria-hidden="true"></span>

    <nav class="primary-nav" aria-label="Primary">
      <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="primary-nav-list">
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
        <span class="sr-only">Menu</span>
      </button>
      <ul class="primary-nav__list" id="primary-nav-list">
        {% for item in nav.primary %}
        <li>
          <a
            href="{{ item.url }}"
            {% if item.external %}target="_blank" rel="noopener"{% endif %}
            {% if page.url == item.url %}aria-current="page"{% endif %}
            class="primary-nav__link{% if page.url == item.url %} is-active{% endif %}"
          >{{ item.label }}</a>
        </li>
        {% endfor %}
      </ul>
    </nav>

    <div class="site-header__actions">
      <a href="{{ nav.applyUrl }}" class="btn btn--gold btn--sm">Apply Now</a>
      <a href="{{ nav.discordUrl }}" class="icon-btn" target="_blank" rel="noopener" aria-label="Join our Discord">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M20.317 4.369A19.79 19.79 0 0 0 15.885 3c-.211.375-.444.879-.608 1.278a18.27 18.27 0 0 0-5.487 0A12.6 12.6 0 0 0 9.182 3 19.74 19.74 0 0 0 4.747 4.373C1.987 8.44 1.24 12.406 1.613 16.317a19.9 19.9 0 0 0 5.993 3.03c.483-.66.913-1.36 1.284-2.098a12.9 12.9 0 0 1-2.023-.973c.17-.124.336-.253.497-.386a14.2 14.2 0 0 0 12.25 0c.163.14.328.269.497.386-.643.383-1.322.71-2.027.975a13.4 13.4 0 0 0 1.283 2.096 19.83 19.83 0 0 0 6-3.03c.44-4.533-.744-8.463-3.05-11.948ZM8.02 13.938c-1.014 0-1.845-.933-1.845-2.078 0-1.145.813-2.08 1.845-2.08 1.032 0 1.862.936 1.845 2.08 0 1.145-.813 2.078-1.845 2.078Zm7.96 0c-1.015 0-1.845-.933-1.845-2.078 0-1.145.813-2.08 1.845-2.08 1.032 0 1.862.936 1.845 2.08 0 1.145-.813 2.078-1.845 2.078Z"/></svg>
      </a>
    </div>
  </div>
</header>
