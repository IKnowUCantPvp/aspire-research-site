          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124ZM7.114 20.452H3.56V9h3.554v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z"/></svg>
          {% else %}
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M20.317 4.369A19.79 19.79 0 0 0 15.885 3c-.211.375-.444.879-.608 1.278a18.27 18.27 0 0 0-5.487 0A12.6 12.6 0 0 0 9.182 3 19.74 19.74 0 0 0 4.747 4.373C1.987 8.44 1.24 12.406 1.613 16.317a19.9 19.9 0 0 0 5.993 3.03c.483-.66.913-1.36 1.284-2.098a12.9 12.9 0 0 1-2.023-.973c.17-.124.336-.253.497-.386a14.2 14.2 0 0 0 12.25 0c.163.14.328.269.497.386-.643.383-1.322.71-2.027.975a13.4 13.4 0 0 0 1.283 2.096 19.83 19.83 0 0 0 6-3.03c.44-4.533-.744-8.463-3.05-11.948ZM8.02 13.938c-1.014 0-1.845-.933-1.845-2.078 0-1.145.813-2.08 1.845-2.08 1.032 0 1.862.936 1.845 2.08 0 1.145-.813 2.078-1.845 2.078Zm7.96 0c-1.015 0-1.845-.933-1.845-2.078 0-1.145.813-2.08 1.845-2.08 1.032 0 1.862.936 1.845 2.08 0 1.145-.813 2.078-1.845 2.078Z"/></svg>
          {% endif %}
        </a>
        {% endfor %}
      </div>

      <p class="site-footer__copyright">© 2026 Aspire Education LLC</p>
    </div>

    <nav class="site-footer__nav" aria-label="Footer">
      <h2 class="site-footer__nav-heading">Navigation</h2>
      <ul>
        {% for item in nav.footer %}
        <li><a href="{{ item.url }}">{{ item.label }}</a></li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</footer>
