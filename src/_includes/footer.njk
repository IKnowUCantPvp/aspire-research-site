<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <a href="/" class="brand brand--footer">
        <img src="/assets/images/logos/aspire-mark.png" alt="" class="brand__mark" width="24" height="24">
        <span>Aspire Research</span>
      </a>
      <p class="site-footer__tagline">The Future of Academic Research for High School Students all across the Country.</p>
      <p class="site-footer__mentor-cta">Want to be a mentor? Check out our <a href="{{ nav.social[1].url }}" target="_blank" rel="noopener">LinkedIn</a>.</p>

      <div class="site-footer__social">
        {% for s in nav.social %}
        <a href="{{ s.url }}" target="_blank" rel="noopener" aria-label="{{ s.label }}" class="icon-btn icon-btn--sm">
