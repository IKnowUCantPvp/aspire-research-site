---
title: Aspire Fellowship
description: "Summer Application Now Open! A selective 12 week program that helps ambitious students create graduate-level research through elite mentorship."
layout: base.njk
---
<section class="hero section--no-border section">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-bg__layer" style="--i:1"></div>
    <div class="hero-bg__layer" style="--i:2"></div>
    <div class="hero-bg__layer" style="--i:3"></div>
  </div>
  <!-- Inline SVG filters for animated velvet effect -->
  <svg aria-hidden="true" width="0" height="0" style="position: absolute;">
    <filter id="velvetTurbulence1">
      <feTurbulence id="turb1" baseFrequency="0.007" numOctaves="3" seed="2" stitchTiles="stitch" />
      <feColorMatrix type="saturate" values="0.2" />
      <feDisplacementMap id="disp1" in="SourceGraphic" scale="30" xChannelSelector="R" yChannelSelector="G" />
      <feGaussianBlur stdDeviation="6" result="blur1" />
    </filter>
    <filter id="velvetTurbulence2">
      <feTurbulence id="turb2" baseFrequency="0.02" numOctaves="2" seed="6" stitchTiles="stitch" />
      <feDisplacementMap id="disp2" in="SourceGraphic" scale="12" xChannelSelector="R" yChannelSelector="G" />
      <feGaussianBlur stdDeviation="8" result="blur2" />
    </filter>
  </svg>

  <div class="hero-velvet" aria-hidden="true"></div>
  <div class="hero__inner">
    <p class="hero__eyebrow">The Aspire Fellowship</p>
    <h1 class="hero-title"><span id="hero-title-text" aria-live="polite"></span><span class="hero-caret" aria-hidden="true">|</span></h1>

    <div class="hero__actions">
      <a href="/access-application/" class="btn btn--gold">Apply now</a>
      <a href="/mission/" class="btn btn--outline">Learn More</a>
    </div>

    <div class="hero__countdown">
      <span class="hero__countdown-label">Early Application Window Closes:</span>
      <div class="countdown">
        <div class="countdown__unit"><span class="countdown__value">00</span><span class="countdown__label">Days</span></div>
        <div class="countdown__unit"><span class="countdown__value">00</span><span class="countdown__label">Hours</span></div>
        <div class="countdown__unit"><span class="countdown__value">00</span><span class="countdown__label">Minutes</span></div>
        <div class="countdown__unit"><span class="countdown__value">00</span><span class="countdown__label">Seconds</span></div>
      </div>
    </div>

    <div class="hero__trust">
      <span class="hero__stars">★★★★★</span>
      <span>Trusted by 20,000+ Students Worldwide</span>
    </div>
  </div>
</section>

